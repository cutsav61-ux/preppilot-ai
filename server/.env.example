# Copy this file to .env and fill in the values.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (or the local docker-compose Mongo)
MONGODB_URI=mongodb://localhost:27017/ai-interview-platform

# Generate strong random secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRY=30d

# AI provider — used from Phase 4 onward, not required for Phase 0/1
# AI_PROVIDER only matters as a tie-breaker: whichever provider actually has
# a configured API key is preferred automatically, regardless of this value.
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# CORS allow-list — the client's origin
CLIENT_URL=http://localhost:3000

# Signs the refresh-token cookie
COOKIE_SECRET=replace-with-another-long-random-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Password-reset emails. If SMTP_HOST is left blank, the server logs the
# reset link to the console instead of sending an email — handy for local
# development. Configure real SMTP credentials (e.g. Mailtrap, SES, Resend
# via SMTP) before deploying.
EMAIL_FROM="AI Interview Platform <no-reply@interview.engine>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
